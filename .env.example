# Copy this file to ".env" and set ROOT_DIR to the folder you want to edit.
# This is usually your OneDrive-synced shared folder.
#
# macOS example:
#   ROOT_DIR=/Users/you/Library/CloudStorage/OneDrive-SharedLibraries-.../SharedNotes
# or a simpler local folder for testing:
#   ROOT_DIR=/Users/you/Documents/notes
#
# Windows example:
#   ROOT_DIR=C:\Users\you\OneDrive\SharedNotes

ROOT_DIR=./sample-notes

# Port the app runs on (open http://localhost:PORT in production mode).
PORT=3001
